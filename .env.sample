# Copy this file to .env and fill in values
# Use a standard mongodb:// URI if your network blocks SRV lookups
MONGO_URI="mongodb://<user>:<password>@host1:27017,host2:27017/<dbname>?replicaSet=YOUR_REPLICA&authSource=admin&retryWrites=true&w=majority"

# JWT secret (already present in your .env)
jwt_secret="KALAI"
